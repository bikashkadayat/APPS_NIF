# Environment configuration template. Copy to `.env` and fill in real values.
# `.env` is gitignored - never commit real secrets.

# ---------------------------------------------------------------------------
# Django core
# ---------------------------------------------------------------------------
# Generate with: python -c "from django.core.management.utils import get_random_secret_key as g; print(g())"
DJANGO_SECRET_KEY=change-me-generate-a-random-key
# "False" in production. When False the app fails fast if any secret is missing.
DJANGO_DEBUG=False
# Explicit host list (no "*") is REQUIRED when DEBUG is False.
# Prod: set this to your domain, e.g. nif.example.com (the prod stack appends
# localhost/127.0.0.1 automatically for the in-container healthcheck).
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Public domain served by the prod reverse proxy (docker-compose.prod.yml).
# Caddy provisions a TLS cert for it. Use SITE_DOMAIN=:80 for a local HTTP test.
# SITE_DOMAIN=nif.example.com

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
DATABASE_ENGINE=postgresql
DATABASE_NAME=leave_system
DATABASE_USER=leave_user
DATABASE_PASSWORD=change-me-strong-db-password
# DATABASE_HOST / DATABASE_PORT are set per environment (db service, localhost).
# DATABASE_CONN_MAX_AGE=60

# ---------------------------------------------------------------------------
# HTTPS / security
# The prod stack (docker-compose.prod.yml) defaults these ON. Override to False
# only for a local HTTP test (e.g. SITE_DOMAIN=:80). The dev stack
# (docker-compose.yml) already forces them off for http://localhost.
# ---------------------------------------------------------------------------
# DJANGO_SECURE_SSL_REDIRECT=True
# DJANGO_SESSION_COOKIE_SECURE=True
# DJANGO_CSRF_COOKIE_SECURE=True
# DJANGO_SECURE_HSTS_SECONDS=31536000
# CSRF origins for admin/session over HTTPS behind your reverse proxy. REQUIRED
# in prod (the prod stack refuses to start without it).
# DJANGO_CSRF_TRUSTED_ORIGINS=https://nif.example.com

# ---------------------------------------------------------------------------
# CORS (usually unused: frontend calls the backend same-origin via the reverse
# proxy). Only needed if the frontend uses an absolute cross-origin API URL.
# ---------------------------------------------------------------------------
# CORS_ALLOW_ALL_ORIGINS=False
# CORS_ALLOWED_ORIGINS=https://nif.example.com

# ---------------------------------------------------------------------------
# Public URLs (email action links + PDF QR verification)
# ---------------------------------------------------------------------------
# FRONTEND_URL=https://nif.example.com
# SITE_URL=https://nif.example.com

# ---------------------------------------------------------------------------
# Email (defaults to console backend - configure SMTP to actually send mail)
# ---------------------------------------------------------------------------
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=no-reply@your-domain

# ---------------------------------------------------------------------------
# Object storage for media (optional; default stores on the container filesystem).
# Requires: pip install "django-storages[boto3]"
# ---------------------------------------------------------------------------
# USE_S3=True
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=
# AWS_S3_ENDPOINT_URL=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ---------------------------------------------------------------------------
# Gunicorn / logging
# ---------------------------------------------------------------------------
# GUNICORN_WORKERS=3
# GUNICORN_TIMEOUT=120
# DJANGO_LOG_LEVEL=INFO
