# Environment configuration template. Copy to `.env` and fill in real values.
# `.env` is gitignored - never commit real secrets.

# ---------------------------------------------------------------------------
# Django core
# ---------------------------------------------------------------------------
# Generate with: python -c "from django.core.management.utils import get_random_secret_key as g; print(g())"
DJANGO_SECRET_KEY=change-me-generate-a-random-key
# "False" in production. When False the app fails fast if any secret is missing.
DJANGO_DEBUG=False
# Explicit host list (no "*") is REQUIRED when DEBUG is False.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
DATABASE_ENGINE=postgresql
DATABASE_NAME=leave_system
DATABASE_USER=leave_user
DATABASE_PASSWORD=change-me-strong-db-password
# DATABASE_HOST / DATABASE_PORT are set per environment (db, localhost, Render host).
# DATABASE_CONN_MAX_AGE=60

# ---------------------------------------------------------------------------
# HTTPS / security (production defaults are ON; override to False for local HTTP)
# ---------------------------------------------------------------------------
# DJANGO_SECURE_SSL_REDIRECT=True
# DJANGO_SESSION_COOKIE_SECURE=True
# DJANGO_CSRF_COOKIE_SECURE=True
# DJANGO_SECURE_HSTS_SECONDS=31536000
# Extra CSRF origins (default already trusts https://*.onrender.com).
# DJANGO_CSRF_TRUSTED_ORIGINS=https://your-app.vercel.app

# ---------------------------------------------------------------------------
# CORS (usually unused: frontend calls the backend same-origin via the Vercel
# rewrite). Only needed if the frontend uses an absolute cross-origin API URL.
# ---------------------------------------------------------------------------
# CORS_ALLOW_ALL_ORIGINS=False
# CORS_ALLOWED_ORIGINS=https://your-app.vercel.app

# ---------------------------------------------------------------------------
# Public URLs (email action links + PDF QR verification)
# ---------------------------------------------------------------------------
# FRONTEND_URL=https://your-app.vercel.app
# SITE_URL=https://your-backend.onrender.com

# ---------------------------------------------------------------------------
# Email (defaults to console backend - configure SMTP to actually send mail)
# ---------------------------------------------------------------------------
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=no-reply@your-domain

# ---------------------------------------------------------------------------
# Object storage for media (optional; default uses the Render persistent disk).
# Requires: pip install "django-storages[boto3]"
# ---------------------------------------------------------------------------
# USE_S3=True
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=
# AWS_S3_ENDPOINT_URL=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ---------------------------------------------------------------------------
# Gunicorn / logging
# ---------------------------------------------------------------------------
# GUNICORN_WORKERS=3
# GUNICORN_TIMEOUT=120
# DJANGO_LOG_LEVEL=INFO
